# Telegram bot tokens — define one per bot (required).
# Replace <BOT_NAME> with a unique identifier such as production, staging, dev, etc.
# TELEGRAM_BOT_TOKEN_production=your_token_here
# TELEGRAM_BOT_TOKEN_staging=your_token_here

# Whisper model used for voice transcription (optional).
WHISPER_MODEL=base

# Timeouts for large file transfers to/from Telegram, in seconds (optional).
TELEGRAM_DOWNLOAD_TIMEOUT=300.0
TELEGRAM_UPLOAD_TIMEOUT=300.0

# Path to the uploads folder where files to be sent are stored (optional).
UPLOADS_PATH=uploads
